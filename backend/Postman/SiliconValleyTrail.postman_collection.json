    {
      "name": "01 - Happy Path / Core Gameplay",
      "item": [
        {
          "name": "Start new game",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/game/start"
            },
            "description": "Starts a new game for the current user."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "if (data.message) pm.collectionVariables.set(\"lastActionMessage\", data.message);",
                  "if (data.pendingEvent && data.pendingEvent.type) {",
                  "  pm.collectionVariables.set(\"lastEventType\", data.pendingEvent.type);",
                  "  const choices = data.pendingEvent.choices || [];",
                  "  if (choices.length > 0 && choices[0].code) {",
                  "    pm.collectionVariables.set(\"eventChoiceCode\", choices[0].code);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
